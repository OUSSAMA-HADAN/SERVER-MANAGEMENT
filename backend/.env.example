APP_USERNAME=
# Bcrypt hash of your login password.
# Generate with: node setup.js
APP_PASSWORD_HASH=$2b$12$replace_me_with_real_bcrypt_hash______________

# Long random string for Express session secret
SESSION_SECRET=change_me_to_a_long_random_string

# Secret used by WebSocket terminal auth. Must match frontend client.
WS_SECRET=change_me_to_a_different_long_random_string

# Port for the backend HTTP + WebSocket server
PORT=3000

# Optional: path used for project disk stats (defaults to backend folder)
# PROJECT_DISK_PATH=/media/srv/741C94C748D7C32A

